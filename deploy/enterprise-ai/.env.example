# Enterprise AI deployment identity
COMPOSE_PROJECT_NAME=enterprise-ai
AICOPILOT_PUBLIC_URL=http://10.98.90.154:82
CLOUD_PLATFORM_URL=http://10.98.90.154:81
AICOPILOT_WEB_PORT=82

# Harbor images. Replace <tag> with the build tag, for example sha-9091b51b1a9ee407.
AICOPILOT_HTTPAPI_IMAGE=10.98.90.154:80/enterprise-ai/aicopilot-httpapi:<tag>
AICOPILOT_MIGRATION_IMAGE=10.98.90.154:80/enterprise-ai/aicopilot-migration:<tag>
AICOPILOT_DATAWORKER_IMAGE=10.98.90.154:80/enterprise-ai/aicopilot-dataworker:<tag>
AICOPILOT_RAGWORKER_IMAGE=10.98.90.154:80/enterprise-ai/aicopilot-ragworker:<tag>
AICOPILOT_WEBUI_IMAGE=10.98.90.154:80/enterprise-ai/aicopilot-webui:<tag>
POSTGRES_IMAGE=10.98.90.154:80/enterprise-ai/base-postgres:17.6
RABBITMQ_IMAGE=10.98.90.154:80/enterprise-ai/base-rabbitmq:4.2-management
QDRANT_IMAGE=10.98.90.154:80/enterprise-ai/base-qdrant:v1.15.5

# Internal data services. Generate strong values on the server .env; do not commit real secrets.
POSTGRES_DB=ai-copilot
POSTGRES_USER=aicopilot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
RABBITMQ_USER=aicopilot
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_RABBITMQ_PASSWORD
QDRANT_KEY=CHANGE_ME_STRONG_QDRANT_KEY

# AICopilot local admin. This is independent from Cloud OIDC until OIDC is enabled.
AICOPILOT_BOOTSTRAP_ADMIN_USERNAME=101650
AICOPILOT_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Application secrets. Generate strong values on the server .env; do not commit real secrets.
AICOPILOT_API_KEY_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_MINIMUM
AICOPILOT_JWT_SECRET_KEY=CHANGE_ME_64_BYTES_MINIMUM
AICOPILOT_ACCESS_TOKEN_EXPIRATION_MINUTES=30

# Phase 1: keep Cloud integration closed. Enable only after Cloud issues the AI read-only service token.
CLOUD_READONLY_MODE=Disabled
CLOUD_READONLY_REAL_ENABLED=false
CLOUD_READONLY_REAL_ALLOW_PRODUCTION_READ=false
CLOUD_AI_READ_ENABLED=false
CLOUD_AI_READ_BASE_URL=http://10.98.90.154:81
CLOUD_AI_READ_TIMEOUT_SECONDS=10
CLOUD_AI_SERVICE_ACCOUNT_TOKEN=

# Phase 3: isolated intranet HTTP Cloud OIDC.
CLOUD_OIDC_ENABLED=true
CLOUD_OIDC_ISSUER=http://10.98.90.154:81
ALLOW_INTRANET_HTTP_OIDC=true
CLOUD_OIDC_CLIENT_ID=aicopilot
CLOUD_OIDC_REQUIRE_HTTPS_METADATA=false
CLOUD_IDENTITY_STATUS_ENABLED=false
CLOUD_IDENTITY_STATUS_BASE_URL=http://10.98.90.154:81
CLOUD_IDENTITY_STATUS_REFRESH_INTERVAL_SECONDS=60
CLOUD_IDENTITY_STATUS_TIMEOUT_SECONDS=5
