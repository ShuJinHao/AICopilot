# Enterprise AI deployment identity
COMPOSE_PROJECT_NAME=enterprise-ai
AICOPILOT_PUBLIC_URL=http://aicopilot.internal.example:82
CLOUD_PLATFORM_URL=http://cloud.internal.example:81
AICOPILOT_WEB_PORT=82

# Harbor images. Replace sha-replace-with-release-tag with the built sha-* tag.
AICOPILOT_HTTPAPI_IMAGE=harbor.internal.example:80/enterprise-ai/aicopilot-httpapi:sha-replace-with-release-tag
AICOPILOT_MIGRATION_IMAGE=harbor.internal.example:80/enterprise-ai/aicopilot-migration:sha-replace-with-release-tag
AICOPILOT_DATAWORKER_IMAGE=harbor.internal.example:80/enterprise-ai/aicopilot-dataworker:sha-replace-with-release-tag
AICOPILOT_RAGWORKER_IMAGE=harbor.internal.example:80/enterprise-ai/aicopilot-ragworker:sha-replace-with-release-tag
AICOPILOT_WEBUI_IMAGE=harbor.internal.example:80/enterprise-ai/aicopilot-webui:sha-replace-with-release-tag
POSTGRES_IMAGE=harbor.internal.example:80/enterprise-ai/base-postgres:17.6
RABBITMQ_IMAGE=harbor.internal.example:80/enterprise-ai/base-rabbitmq:4.2-management
QDRANT_IMAGE=harbor.internal.example:80/enterprise-ai/base-qdrant:v1.15.5

# Internal data services. Generate strong values on the server .env; do not commit real secrets.
POSTGRES_DB=ai-copilot
POSTGRES_USER=aicopilot
POSTGRES_PASSWORD=
RABBITMQ_USER=aicopilot
RABBITMQ_PASSWORD=
QDRANT_KEY=

# Runtime file roots. These must be writable by the non-root app user and shared by backend workers.
AICOPILOT_FILE_STORAGE_ROOT_PATH=/var/lib/aicopilot/storage
AICOPILOT_ARTIFACT_WORKSPACE_ROOT_PATH=/var/lib/aicopilot/artifact-workspaces

# AICopilot local emergency admin. Use a site-specific account name; do not copy an employee number into the template.
AICOPILOT_BOOTSTRAP_ADMIN_USERNAME=bootstrap-admin
AICOPILOT_BOOTSTRAP_ADMIN_PASSWORD=

# Application secrets. Generate strong values on the server .env; do not commit real secrets.
AICOPILOT_API_KEY_ENCRYPTION_KEY=
AICOPILOT_JWT_SECRET_KEY=
AICOPILOT_ACCESS_TOKEN_EXPIRATION_MINUTES=30

# Phase 1: keep Cloud integration closed. Enable only after Cloud issues the AI read-only service token.
CLOUD_READONLY_MODE=Disabled
CLOUD_READONLY_REAL_ENABLED=false
CLOUD_READONLY_REAL_ALLOW_PRODUCTION_READ=false
CLOUD_AI_READ_ENABLED=false
CLOUD_AI_READ_BASE_URL=http://cloud.internal.example:81
CLOUD_AI_READ_TIMEOUT_SECONDS=10
CLOUD_AI_SERVICE_ACCOUNT_TOKEN=

# Direct DataAnalysis Cloud read-only DB. Leave disabled unless a verified read-only DB account is configured.
DATA_ANALYSIS_CLOUD_READONLY_ENABLED=false
DATA_ANALYSIS_CLOUD_READONLY_DATABASE_NAME=DeviceSemanticReadonly
DATA_ANALYSIS_CLOUD_READONLY_CONNECTION_STRING=
DATA_ANALYSIS_CLOUD_READONLY_CREDENTIAL_VERIFIED=false
DATA_ANALYSIS_CLOUD_READONLY_DEFAULT_QUERY_LIMIT=200
DATA_ANALYSIS_CLOUD_READONLY_MAX_QUERY_LIMIT=1000
DATA_ANALYSIS_CLOUD_READONLY_DOCKER_NETWORK=enterprise-ai-cloud-readonly
DATA_ANALYSIS_CLOUD_READONLY_DB_HOST_ALIAS=cloud-postgres
DATA_ANALYSIS_CLOUD_READONLY_CLOUD_COMPOSE_PROJECT=deploy
DATA_ANALYSIS_CLOUD_READONLY_CLOUD_POSTGRES_SERVICE=postgres

# Optional server-side private model smoke check. Configure endpoint, model, and API key only in the real server .env.
AICOPILOT_PRIVATE_MODEL_ENABLED=false
AICOPILOT_PRIVATE_MODEL_PROVIDER=MiniMax Private
AICOPILOT_PRIVATE_MODEL_NAME=MiniMax-M3-AWQ-INT4
AICOPILOT_PRIVATE_MODEL_BASE_URL=http://model.internal.example:40034/v1
AICOPILOT_PRIVATE_MODEL_API_KEY=
AICOPILOT_PRIVATE_MODEL_CONTEXT_TOKENS=65536
AICOPILOT_PRIVATE_MODEL_MAX_OUTPUT_TOKENS=4096
AICOPILOT_PRIVATE_MODEL_TEMPERATURE=0.2

AICOPILOT_MODEL_SMOKE_ENABLED=false
AICOPILOT_MODEL_SMOKE_BASE_URL=http://model.internal.example:40034/v1
AICOPILOT_MODEL_SMOKE_MODEL=MiniMax-M3-AWQ-INT4
AICOPILOT_MODEL_SMOKE_API_KEY=
AICOPILOT_MODEL_SMOKE_ALLOW_DUMMY_KEY=false
AICOPILOT_MODEL_SMOKE_TIMEOUT_SECONDS=10

# Phase 3: isolated intranet HTTP Cloud OIDC.
CLOUD_OIDC_ENABLED=true
CLOUD_OIDC_ISSUER=http://cloud.internal.example:81
ALLOW_INTRANET_HTTP_OIDC=true
CLOUD_OIDC_CLIENT_ID=aicopilot
CLOUD_OIDC_REQUIRE_HTTPS_METADATA=false
CLOUD_OIDC_BOOTSTRAP_ADMIN_AUTO_BIND_ENABLED=false
CLOUD_IDENTITY_STATUS_ENABLED=false
CLOUD_IDENTITY_STATUS_BASE_URL=http://cloud.internal.example:81
CLOUD_IDENTITY_STATUS_REFRESH_INTERVAL_SECONDS=60
CLOUD_IDENTITY_STATUS_TIMEOUT_SECONDS=5
