ARG RUNTIME_BASE_IMAGE=10.98.90.154:80/enterprise-ai/base-dotnet-aspnet:10.0-noble

FROM ${RUNTIME_BASE_IMAGE} AS runtime

USER root

RUN apt-get -o Acquire::Retries=5 update \
    && DEBIAN_FRONTEND=noninteractive apt-get -o Acquire::Retries=5 install -y --no-install-recommends \
        libgssapi-krb5-2 \
        tzdata \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

ARG APP_DLL
RUN test -n "${APP_DLL}" \
    && test -f "${APP_DLL}" \
    && ln -sf "${APP_DLL}" AICopilot.App.dll

RUN mkdir -p /var/lib/aicopilot/storage /var/lib/aicopilot/artifact-workspaces \
    && chown -R app:app /var/lib/aicopilot

ENV DOTNET_RUNNING_IN_CONTAINER=true \
    TZ=Asia/Shanghai

USER app

ENTRYPOINT ["dotnet", "AICopilot.App.dll"]
