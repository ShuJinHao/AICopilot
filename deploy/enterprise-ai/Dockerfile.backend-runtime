ARG RUNTIME_BASE_IMAGE=harbor.internal.example:80/enterprise-ai/base-dotnet-aspnet:10.0-noble

FROM ${RUNTIME_BASE_IMAGE} AS runtime

USER app
WORKDIR /app

COPY --chown=app:app . .

ARG APP_DLL
RUN test -n "${APP_DLL}" \
    && test -f "${APP_DLL}" \
    && ln -sf "${APP_DLL}" AICopilot.App.dll

ENV DOTNET_RUNNING_IN_CONTAINER=true \
    TZ=Asia/Shanghai

ENTRYPOINT ["dotnet", "AICopilot.App.dll"]
