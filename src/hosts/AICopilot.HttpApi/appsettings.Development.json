{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AiGateway": {
    "FinalAgentContextStore": {
      "Provider": "Memory"
    }
  },
  "AgentRunQueue": {
    "LeaseDurationSeconds": 300,
    "HeartbeatActiveWindowSeconds": 30,
    "MaxRetryAttempts": 3,
    "RetryBackoffSeconds": 30,
    "MaxRetryBackoffSeconds": 300,
    "StaleLeaseAction": "Fail"
  },
  "JwtSettings": {
    "Issuer": "https://localhost",
    "Audience": "https://localhost",
    "AccessTokenExpirationMinutes": 30
  },
  "CloudOidc": {
    "Enabled": true,
    "Issuer": "http://localhost:8080",
    "ClientId": "aicopilot",
    "CallbackPath": "/api/identity/cloud-oidc/callback",
    "FrontendCompletionPath": "/cloud-login/complete",
    "RequireHttpsMetadata": false,
    "BootstrapAdminAutoBindEnabled": false,
    "BootstrapAdminUserName": "",
    "ExternalCookieLifetimeMinutes": 5,
    "Scopes": [ "openid", "profile" ]
  },
  "CloudIdentityStatus": {
    "Enabled": false,
    "BaseUrl": "http://localhost:8080",
    "StatusEndpointPath": "/api/v1/ai/identity/users/{cloudUserId}/status",
    "ServiceAccountToken": "",
    "RefreshIntervalSeconds": 60,
    "TimeoutSeconds": 5,
    "FailureMode": "RejectWhenUnverified"
  },
  "CloudReadonly": {
    "Mode": "Disabled",
    "Simulation": {
      "Enabled": false,
      "SeedData": true,
      "DataSet": "ManufacturingDemo",
      "AlwaysMarkAsSimulation": true
    },
    "Real": {
      "Enabled": false,
      "AllowProductionRead": false
    }
  },
  "CloudAiRead": {
    "Enabled": false,
    "BaseUrl": "http://localhost:8080",
    "ServiceAccountToken": "",
    "TimeoutSeconds": 10,
    "DefaultPassStationTypeKey": "default",
    "ExplicitPostQueryPaths": []
  },
  "CloudReadonlySandbox": {
    "Enabled": false,
    "BaseUrl": "",
    "ServiceAccountToken": "",
    "TimeoutSeconds": 10,
    "EnvironmentLabel": "RealSandbox",
    "DefaultPassStationTypeKey": "default",
    "ExplicitPostQueryPaths": []
  },
  "CloudReadonlySandboxAgentTrial": {
    "Enabled": false,
    "AllowedScenarioIds": [
      "cloud-sandbox-devices",
      "cloud-sandbox-capacity-summary",
      "cloud-sandbox-device-logs",
      "cloud-sandbox-pass-station-records",
      "cloud-sandbox-device-exception-analysis",
      "cloud-sandbox-capacity-delivery-analysis"
    ],
    "MaxRows": 20,
    "TimeoutMs": 5000,
    "RequiresToolApproval": true,
    "RequiresFinalApproval": true
  },
  "CloudReadonlySandboxControlledTrial": {
    "Enabled": false,
    "FreeGoalEnabled": true,
    "AllowedEndpointCodes": [
      "devices",
      "capacity_summary",
      "device_logs",
      "pass_station_records"
    ],
    "AllowedArtifactTypes": [
      "Chart",
      "Markdown",
      "Html",
      "Pdf",
      "Pptx",
      "Xlsx"
    ],
    "MaxTimeRangeDays": 31,
    "DefaultMaxRows": 20,
    "MaxRows": 50,
    "TimeoutMs": 5000,
    "RequiresToolApproval": true,
    "RequiresFinalApproval": true
  },
  "CloudReadonlyPilotReadiness": {
    "Enabled": false,
    "AllowedEndpointCodes": [
      "devices",
      "capacity_summary",
      "device_logs",
      "pass_station_records"
    ],
    "MaxTimeRangeDays": 7,
    "DefaultMaxRows": 20,
    "MaxRows": 50,
    "TimeoutMs": 5000,
    "ApprovalPolicy": "PilotReadinessRehearsal",
    "RollbackPolicy": "DisablePilotConfigAndKeepProductionToolsClosed",
    "OwnerDepartment": "AI Platform",
    "RequiresToolApproval": true,
    "RequiresFinalApproval": true
  },
  "CloudReadonlyProductionPilot": {
    "Enabled": false,
    "AllowedEndpointCodes": [
      "devices",
      "capacity_summary",
      "device_logs",
      "pass_station_records"
    ],
    "AllowedScenarioIds": [
      "cloud-production-pilot-devices",
      "cloud-production-pilot-capacity-summary",
      "cloud-production-pilot-device-logs",
      "cloud-production-pilot-pass-station-records",
      "cloud-production-pilot-device-exception-analysis",
      "cloud-production-pilot-capacity-delivery-analysis"
    ],
    "AllowedArtifactTypes": [
      "Chart",
      "Markdown",
      "Html",
      "Pdf",
      "Pptx",
      "Xlsx"
    ],
    "MaxTimeRangeDays": 7,
    "DefaultMaxRows": 20,
    "MaxRows": 50,
    "TimeoutMs": 5000,
    "ApprovalPolicy": "ProductionPilotToolApproval",
    "RollbackPolicy": "EmergencyDisableProductionPilot",
    "OwnerDepartment": "AI Platform",
    "RequiresToolApproval": true,
    "RequiresFinalApproval": true
  },
  "CloudReadonlyProductionControlledPilot": {
    "Enabled": false,
    "FreeGoalEnabled": false,
    "AllowedEndpointCodes": [
      "devices",
      "capacity_summary",
      "device_logs",
      "pass_station_records"
    ],
    "AllowedArtifactTypes": [
      "Chart",
      "Markdown",
      "Html",
      "Pdf",
      "Pptx",
      "Xlsx"
    ],
    "MaxTimeRangeDays": 7,
    "DefaultMaxRows": 20,
    "MaxRows": 50,
    "TimeoutMs": 5000,
    "RequiresToolApproval": true,
    "RequiresFinalApproval": true,
    "ApprovalPolicy": "ProductionControlledPilotToolApproval",
    "RollbackPolicy": "EmergencyDisableProductionControlledPilot"
  },
  "Mcp": {
    "Runtime": {
      "Enabled": false,
      "MockOnly": true,
      "RefreshIntervalSeconds": 30
    }
  },
  "SemanticMappings": {
    "DatabaseName": "DeviceSemanticReadonly",
    "Device": {
      "SourceName": "device_master_cloud_sim_view"
    },
    "DeviceLog": {
      "SourceName": "device_log_cloud_sim_view"
    },
    "Capacity": {
      "SourceName": "capacity_cloud_sim_view"
    },
    "ProductionData": {
      "SourceName": "production_data_cloud_sim_view"
    }
  }
}
