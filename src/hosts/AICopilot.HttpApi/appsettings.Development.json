{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AiGateway": {
    "FinalAgentContextStore": {
      "Provider": "Memory"
    }
  },
  "JwtSettings": {
    "Issuer": "https://localhost",
    "Audience": "https://localhost",
    "AccessTokenExpirationMinutes": 30
  },
  "SemanticMappings": {
    "DatabaseName": "DeviceSemanticReadonly",
    "Device": {
      "SourceName": "device_master_cloud_sim_view"
    },
    "DeviceLog": {
      "SourceName": "device_log_cloud_sim_view"
    },
    "Recipe": {
      "SourceName": "recipe_cloud_sim_view"
    },
    "Capacity": {
      "SourceName": "capacity_cloud_sim_view"
    },
    "ProductionData": {
      "SourceName": "production_data_cloud_sim_view"
    }
  }
}
