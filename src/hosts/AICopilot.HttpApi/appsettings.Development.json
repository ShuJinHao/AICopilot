{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AiGateway": {
    "FinalAgentContextStore": {
      "Provider": "Memory"
    }
  },
  "JwtSettings": {
    "Issuer": "https://localhost",
    "Audience": "https://localhost",
    "AccessTokenExpirationMinutes": 30
  },
  "CloudOidc": {
    "Enabled": true,
    "Issuer": "http://localhost:8080",
    "ClientId": "aicopilot",
    "CallbackPath": "/api/identity/cloud-oidc/callback",
    "FrontendCompletionPath": "/cloud-login/complete",
    "RequireHttpsMetadata": false,
    "ExternalCookieLifetimeMinutes": 5,
    "Scopes": [ "openid", "profile" ]
  },
  "CloudIdentityStatus": {
    "Enabled": false,
    "BaseUrl": "http://localhost:8080",
    "StatusEndpointPath": "/api/v1/ai/identity/users/{cloudUserId}/status",
    "ServiceAccountToken": "",
    "RefreshIntervalSeconds": 60,
    "TimeoutSeconds": 5,
    "FailureMode": "RejectWhenUnverified"
  },
  "CloudAiRead": {
    "Enabled": false,
    "BaseUrl": "http://localhost:8080",
    "ServiceAccountToken": "",
    "TimeoutSeconds": 10,
    "DefaultPassStationTypeKey": "default",
    "ExplicitPostQueryPaths": []
  },
  "SemanticMappings": {
    "DatabaseName": "DeviceSemanticReadonly",
    "Device": {
      "SourceName": "device_master_cloud_sim_view"
    },
    "DeviceLog": {
      "SourceName": "device_log_cloud_sim_view"
    },
    "Capacity": {
      "SourceName": "capacity_cloud_sim_view"
    },
    "ProductionData": {
      "SourceName": "production_data_cloud_sim_view"
    }
  }
}
