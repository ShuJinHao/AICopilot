{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AiGateway": {
    "FinalAgentContextStore": {
      "Provider": "Redis"
    }
  },
  "CloudOidc": {
    "Enabled": false,
    "Issuer": "",
    "ClientId": "aicopilot",
    "CallbackPath": "/api/identity/cloud-oidc/callback",
    "FrontendCompletionPath": "/cloud-login/complete",
    "RequireHttpsMetadata": true,
    "ExternalCookieLifetimeMinutes": 5,
    "Scopes": [ "openid", "profile" ]
  },
  "CloudIdentityStatus": {
    "Enabled": false,
    "BaseUrl": "",
    "StatusEndpointPath": "/api/v1/ai/identity/users/{cloudUserId}/status",
    "ServiceAccountToken": "",
    "RefreshIntervalSeconds": 60,
    "TimeoutSeconds": 5,
    "FailureMode": "RejectWhenUnverified"
  },
  "AllowedHosts": "*"
}
