<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <AICopilotTestKind>Integration</AICopilotTestKind>
    <AICopilotTestRuntime>Aspire</AICopilotTestRuntime>
    <AICopilotTestCadence>PR</AICopilotTestCadence>
    <AICopilotTestOwner>IdentityHttp</AICopilotTestOwner>
    <AICopilotRequired>true</AICopilotRequired>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Aspire.Hosting" Version="13.2.2" />
    <PackageReference Include="Aspire.Hosting.Testing" Version="13.2.2" />
    <PackageReference Include="FluentAssertions" Version="8.8.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\hosts\AICopilot.AppHost\AICopilot.AppHost.csproj" />
    <ProjectReference Include="..\..\hosts\AICopilot.HttpApi\AICopilot.HttpApi.csproj" />
    <ProjectReference Include="..\..\services\AICopilot.Services.Contracts\AICopilot.Services.Contracts.csproj" />
    <ProjectReference Include="..\..\shared\AICopilot.SharedKernel\AICopilot.SharedKernel.csproj" />
    <ProjectReference Include="..\..\testing\AICopilot.AspireIntegrationTestKit\AICopilot.AspireIntegrationTestKit.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="Aspire.Hosting.ApplicationModel" />
    <Using Include="AICopilot.AspireIntegrationTestKit" />
    <Using Include="FluentAssertions" />
    <Using Include="Microsoft.Extensions.DependencyInjection" />
    <Using Include="Xunit" />
  </ItemGroup>
  <Import Project="..\AICopilot.TestRunner.Shared.props" />
</Project>
