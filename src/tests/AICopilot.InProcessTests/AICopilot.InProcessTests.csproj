<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <AICopilotTestKind>Integration</AICopilotTestKind>
    <AICopilotTestRuntime>InProcess</AICopilotTestRuntime>
    <AICopilotTestCadence>PR</AICopilotTestCadence>
    <AICopilotTestOwner>InProcessBoundary</AICopilotTestOwner>
    <AICopilotRequired>true</AICopilotRequired>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="FluentAssertions" Version="8.8.0" />
