{
  "stryker-config": {
    "project": "AICopilot.EntityFrameworkCore.csproj",
    "mutate": [
      "Security/SecretStringEncryptor.cs"
    ],
    "mutation-level": "Standard",
    "configuration": "Release",
    "target-framework": "net10.0",
    "reporters": [
      "json",
      "markdown",
      "dots"
    ],
    "report-file-name": "aicopilot-secret-encryption-mutation",
    "concurrency": 2,
    "break-on-initial-test-failure": true,
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    }
  }
}
